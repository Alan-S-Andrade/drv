<?xml version="1.0" encoding="UTF-8"?>
<!--
  McPAT configuration for DRV PandoHammer single-pod design.

  Configuration:
    - 1 pod, 64 cores (8x8), 16 harts per core (1024 total harts)
    - L1SP: 128 KiB per core (scratchpad, modeled as direct-mapped L1D)
    - L2SP: 1 MiB total, 8 banks of 128 KiB each (modeled as shared L2)
    - NoC: single-router crossbar, 64-bit flits, 73 ports
    - Technology: 22 nm, 1 GHz, 360 K
    - ISA: RV64IMAF, 1-wide in-order barrel multithreaded

  Activity stats filled from:
    bfs_64c/drvr/drvr-run-bfs_work_stealing_adaptive/stats.csv
    (64-core work-stealing adaptive BFS on RMAT graph)

  Per-core values: aggregate / 64 cores.
  Per-L2-bank values: aggregate / 8 banks.

  McPAT v1.3 requires components in strict positional order:
    core0, [L1Dir0], [L2Dir0], L20, [L30], NoC0, mc, niu, pcie, flashc
-->
